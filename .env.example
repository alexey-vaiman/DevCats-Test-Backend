# Backend local development configuration
# Copy this to .env (inside backend/ directory) for run_seed.sh or local uvicorn.

DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/marketplace
SECRET_KEY=secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=marketplace-images
S3_PUBLIC_URL_PREFIX=http://localhost:9000/marketplace-images

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

BACKEND_CORS_ORIGINS="http://localhost:5173,http://localhost:8000"
